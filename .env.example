# =============================================================================
# capability-network 环境变量
# 复制为 .env 后按需修改：cp .env.example .env
# =============================================================================

# --- 应用 ---
APP_NAME=capability-network-backend
APP_VERSION=0.1.0
DEBUG=false

# --- 可选：Sentry 错误监控（未配置则跳过）---
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=production
# SENTRY_TRACES_SAMPLE_RATE=0.1

# --- Backend 服务 ---
BACKEND_PORT=8000

# --- PostgreSQL ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=capability_network
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/capability_network

# --- Redis ---
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# --- JWT（实现阶段使用）---
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- CORS ---
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- 本地 Windows 无 Docker：设为 1 使用 database-schema-local.sql（无 pgvector）---
LOCAL_SCHEMA=0

# --- 数据库备份（可选）---
# BACKUP_DIR=/www/wwwroot/capability-network/backups
# BACKUP_DRY_RUN=false

# --- Frontend ---
VITE_API_URL=http://localhost:8000/api/v1

# --- MCP Server（占位，后续会话使用）---
MCP_SERVER_PORT=3001
MCP_API_KEY=change-me-in-production
