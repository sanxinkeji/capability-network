# 复制为 backend/.env 后修改

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/capability_network
REDIS_URL=redis://localhost:6379/0
JWT_SECRET_KEY=请替换为随机长字符串
DEBUG=true
CORS_ORIGINS=http://localhost:5173,https://你的域名.com

# 公网 API 根地址（支付回调 notify_url 依赖此项）
PUBLIC_BASE_URL=https://api.你的域名.com

# 支付渠道：wechat | alipay（生产勿用 test）
PAYMENT_PROVIDER=wechat
MIN_DEPOSIT_CENTS=100
MIN_WITHDRAW_CENTS=10000

# API 安全（生产建议 DEBUG=false 并配置 Redis）
RATE_LIMIT_ENABLED=true
RATE_LIMIT_LOGIN_MAX=10
RATE_LIMIT_LOGIN_WINDOW_SECONDS=60
RATE_LIMIT_REGISTER_MAX=5
RATE_LIMIT_REGISTER_WINDOW_SECONDS=3600
RATE_LIMIT_PAYMENT_NOTIFY_MAX=100
RATE_LIMIT_PAYMENT_NOTIFY_WINDOW_SECONDS=60
RATE_LIMIT_API_KEY_ISSUE_MAX=10
RATE_LIMIT_API_KEY_ISSUE_WINDOW_SECONDS=3600
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_SECONDS=900
LOGIN_LOCKOUT_SCOPE=account

# 可选：Sentry 错误监控（未配置则跳过）
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=production
# SENTRY_TRACES_SAMPLE_RATE=0.1

# 微信支付 v3（Native 扫码）
WECHAT_PAY_APP_ID=
WECHAT_PAY_MCH_ID=
WECHAT_PAY_API_V3_KEY=
WECHAT_PAY_CERT_SERIAL=
WECHAT_PAY_PRIVATE_KEY_PATH=/path/to/apiclient_key.pem

# 支付宝（当面付 precreate）
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY_PATH=/path/to/alipay_private_key.pem
ALIPAY_PUBLIC_KEY_PATH=/path/to/alipay_public_key.pem
ALIPAY_GATEWAY=https://openapi.alipay.com/gateway.do

# 可选：LLM 需求解析
# LLM_API_KEY=
# LLM_BASE_URL=
